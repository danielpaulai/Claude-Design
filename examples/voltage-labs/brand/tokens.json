{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Voltage Labs design tokens. Generated by brand-in-a-box from INTAKE-EXAMPLE.md. Cinematic Dark family.",
  "color": {
    "brand": {
      "cyan": {
        "$value": "#00d4ff",
        "$type": "color",
        "$description": "Primary accent. CTAs, eyebrows, technical labels, code highlights. Glows on near-black."
      },
      "pearl": {
        "$value": "#f5f5f7",
        "$type": "color",
        "$description": "Primary text on dark. Slightly off-white for less harshness than pure white."
      },
      "iron": {
        "$value": "#2c2c30",
        "$type": "color",
        "$description": "Borders, dividers, subtle UI separators."
      }
    },
    "neutral": {
      "void": { "$value": "#000000", "$type": "color", "$description": "Default canvas. Pure black. The brand is unapologetic about it." },
      "charcoal": { "$value": "#0a0a0c", "$type": "color", "$description": "Card and elevated surfaces against void." },
      "graphite": { "$value": "#16161a", "$type": "color", "$description": "Higher elevation, hover states." },
      "ash": { "$value": "#1f1f23", "$type": "color" },
      "smoke": { "$value": "#6e6e73", "$type": "color", "$description": "Secondary text." },
      "fog": { "$value": "#98989d", "$type": "color", "$description": "Tertiary text, muted UI labels." }
    },
    "semantic": {
      "text-primary": { "$value": "{color.brand.pearl}", "$type": "color" },
      "text-secondary": { "$value": "{color.neutral.fog}", "$type": "color" },
      "text-muted": { "$value": "{color.neutral.smoke}", "$type": "color" },
      "background-default": { "$value": "{color.neutral.void}", "$type": "color" },
      "background-subtle": { "$value": "{color.neutral.charcoal}", "$type": "color" },
      "background-elevated": { "$value": "{color.neutral.graphite}", "$type": "color" },
      "accent": { "$value": "{color.brand.cyan}", "$type": "color" },
      "border-default": { "$value": "{color.brand.iron}", "$type": "color" },
      "border-strong": { "$value": "{color.neutral.smoke}", "$type": "color" }
    }
  },
  "typography": {
    "family": {
      "heading": {
        "$value": "Space Grotesk",
        "$type": "fontFamily",
        "$description": "Geometric sans for headlines. Family default for Cinematic Dark. Free on Google Fonts."
      },
      "body": {
        "$value": "Inter",
        "$type": "fontFamily",
        "$description": "Clean sans for body and UI."
      },
      "mono": {
        "$value": "JetBrains Mono",
        "$type": "fontFamily",
        "$description": "For technical labels, code, version strings, eyebrows."
      }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "xs": { "$value": "11px", "$type": "dimension" },
      "sm": { "$value": "13px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "18px", "$type": "dimension" },
      "xl": { "$value": "22px", "$type": "dimension" },
      "2xl": { "$value": "28px", "$type": "dimension" },
      "3xl": { "$value": "36px", "$type": "dimension" },
      "4xl": { "$value": "48px", "$type": "dimension" },
      "5xl": { "$value": "64px", "$type": "dimension" },
      "6xl": { "$value": "88px", "$type": "dimension", "$description": "Hero on 1440-wide landing pages." },
      "7xl": { "$value": "120px", "$type": "dimension", "$description": "Display on landing hero. Cinematic scale." }
    },
    "lineHeight": {
      "tight": { "$value": 1.05, "$type": "number", "$description": "Hero text. Cinematic Dark headlines are tight." },
      "snug": { "$value": 1.2, "$type": "number" },
      "normal": { "$value": 1.5, "$type": "number" }
    },
    "letterSpacing": {
      "tighter": { "$value": "-0.04em", "$type": "dimension", "$description": "Hero scale only." },
      "tight": { "$value": "-0.02em", "$type": "dimension" },
      "normal": { "$value": "0em", "$type": "dimension" },
      "wide": { "$value": "0.12em", "$type": "dimension", "$description": "Mono eyebrows. More open than other families." }
    },
    "style": {
      "display": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.7xl}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.tighter}"
        }
      },
      "hero": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.6xl}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "h1": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.5xl}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "eyebrow": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.mono}",
          "fontWeight": "{typography.weight.medium}",
          "fontSize": "{typography.size.xs}",
          "letterSpacing": "{typography.letterSpacing.wide}"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.base}",
          "lineHeight": "{typography.lineHeight.normal}"
        }
      }
    }
  },
  "spacing": {
    "0": { "$value": "0px", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0px", "$type": "dimension" },
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "6px", "$type": "dimension", "$description": "Default for cards. Tight, mechanical." },
    "lg": { "$value": "12px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "canvas": {
    "linkedin-post": { "$value": { "width": 1080, "height": 1350 }, "$type": "dimension" },
    "linkedin-banner": { "$value": { "width": 1584, "height": 396 }, "$type": "dimension" },
    "pitch-deck": { "$value": { "width": 1920, "height": 1080 }, "$type": "dimension" },
    "landing-page": { "$value": { "width": 1440, "height": 1024 }, "$type": "dimension" }
  }
}
