{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Purely Personal design tokens. Generated by brand-in-a-box from INTAKE.md. Source of truth for Canva, Figma, PDF pipelines, CSS, and any downstream tool.",
  "color": {
    "brand": {
      "red": {
        "$value": "#e90d41",
        "$type": "color",
        "$description": "Primary accent. CTAs, headers, highlights. Cap at 5% of any frame."
      },
      "near-black": {
        "$value": "#0a0a0a",
        "$type": "color",
        "$description": "Body text and dark backgrounds. Never pure black."
      },
      "silver": {
        "$value": "#b8bec1",
        "$type": "color",
        "$description": "Secondary text, hairline borders, muted UI."
      }
    },
    "neutral": {
      "white": { "$value": "#ffffff", "$type": "color" },
      "off-white": { "$value": "#f7f7f8", "$type": "color", "$description": "Paper canvas. Full-bleed in cheatsheets and one-pagers." },
      "gray-100": { "$value": "#e8eaec", "$type": "color" },
      "gray-300": { "$value": "#b8bec1", "$type": "color", "$description": "Same as brand.silver. Kept here for neutral semantic." },
      "gray-500": { "$value": "#6b7075", "$type": "color" },
      "gray-700": { "$value": "#3a3d40", "$type": "color" }
    },
    "semantic": {
      "text-primary": { "$value": "{color.brand.near-black}", "$type": "color" },
      "text-secondary": { "$value": "{color.neutral.gray-500}", "$type": "color" },
      "text-muted": { "$value": "{color.brand.silver}", "$type": "color" },
      "text-on-dark": { "$value": "{color.neutral.white}", "$type": "color" },
      "background-default": { "$value": "{color.neutral.white}", "$type": "color" },
      "background-subtle": { "$value": "{color.neutral.off-white}", "$type": "color" },
      "background-inverse": { "$value": "{color.brand.near-black}", "$type": "color" },
      "accent": { "$value": "{color.brand.red}", "$type": "color" },
      "border-default": { "$value": "{color.neutral.gray-100}", "$type": "color" },
      "border-strong": { "$value": "{color.brand.silver}", "$type": "color" }
    }
  },
  "typography": {
    "family": {
      "heading": {
        "$value": "Rethink Sans",
        "$type": "fontFamily",
        "$description": "Family default for Editorial Minimal. Headlines, titles, slide headers. Never substitute Poppins."
      },
      "body": {
        "$value": "Inter",
        "$type": "fontFamily",
        "$description": "Body copy, captions, descriptions, UI text."
      }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight" }
    },
    "size": {
      "xs": { "$value": "12px", "$type": "dimension" },
      "sm": { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "18px", "$type": "dimension" },
      "xl": { "$value": "20px", "$type": "dimension" },
      "2xl": { "$value": "24px", "$type": "dimension" },
      "3xl": { "$value": "32px", "$type": "dimension" },
      "4xl": { "$value": "40px", "$type": "dimension" },
      "5xl": { "$value": "56px", "$type": "dimension" },
      "6xl": { "$value": "72px", "$type": "dimension", "$description": "Hero headlines, carousel cover slides." }
    },
    "lineHeight": {
      "tight": { "$value": 1.1, "$type": "number" },
      "snug": { "$value": 1.25, "$type": "number" },
      "normal": { "$value": 1.5, "$type": "number" },
      "relaxed": { "$value": 1.65, "$type": "number" }
    },
    "letterSpacing": {
      "tight": { "$value": "-0.02em", "$type": "dimension" },
      "normal": { "$value": "0em", "$type": "dimension" },
      "wide": { "$value": "0.04em", "$type": "dimension" }
    },
    "style": {
      "hero": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.6xl}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "h1": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.5xl}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "h2": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.4xl}",
          "lineHeight": "{typography.lineHeight.snug}"
        }
      },
      "h3": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.semibold}",
          "fontSize": "{typography.size.3xl}",
          "lineHeight": "{typography.lineHeight.snug}"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.base}",
          "lineHeight": "{typography.lineHeight.normal}"
        }
      },
      "caption": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.sm}",
          "lineHeight": "{typography.lineHeight.normal}"
        }
      }
    }
  },
  "spacing": {
    "0": { "$value": "0px", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0px", "$type": "dimension" },
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "canvas": {
    "linkedin-post": { "$value": { "width": 1080, "height": 1350 }, "$type": "dimension", "$description": "LinkedIn vertical image, carousel slide." },
    "linkedin-pdf": { "$value": { "width": 1080, "height": 1350 }, "$type": "dimension" },
    "cheatsheet": { "$value": { "width": 1080, "height": 1350 }, "$type": "dimension" },
    "one-pager": { "$value": { "width": 2480, "height": 3508 }, "$type": "dimension", "$description": "A4 at 300dpi for print and high-res PDF." }
  }
}
