{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Marigold & Oak design tokens. Generated by brand-in-a-box from INTAKE-EXAMPLE.md. Warm Editorial family.",
  "color": {
    "brand": {
      "terracotta": {
        "$value": "#c8543b",
        "$type": "color",
        "$description": "Primary accent. CTAs, headlines, highlight words. Warmer than red, less aggressive."
      },
      "ink": {
        "$value": "#1a1814",
        "$type": "color",
        "$description": "Body text and dark backgrounds. Has slight brown undertone, never pure black."
      },
      "sage": {
        "$value": "#7d8a73",
        "$type": "color",
        "$description": "Secondary accent. Use for tags, secondary CTAs, soft separators."
      }
    },
    "neutral": {
      "warm-white": { "$value": "#fbf8f3", "$type": "color", "$description": "Default canvas. Warmer than off-white." },
      "cream": { "$value": "#f4ede4", "$type": "color", "$description": "Card backgrounds, subtle section breaks." },
      "stone": { "$value": "#9a8e7e", "$type": "color", "$description": "Muted text, captions." },
      "warm-gray-100": { "$value": "#e8e0d3", "$type": "color" },
      "warm-gray-300": { "$value": "#c4baa8", "$type": "color" },
      "warm-gray-500": { "$value": "#7d7163", "$type": "color" },
      "warm-gray-700": { "$value": "#4a4239", "$type": "color" }
    },
    "semantic": {
      "text-primary": { "$value": "{color.brand.ink}", "$type": "color" },
      "text-secondary": { "$value": "{color.neutral.warm-gray-500}", "$type": "color" },
      "text-muted": { "$value": "{color.neutral.stone}", "$type": "color" },
      "text-on-dark": { "$value": "{color.neutral.warm-white}", "$type": "color" },
      "background-default": { "$value": "{color.neutral.warm-white}", "$type": "color" },
      "background-subtle": { "$value": "{color.neutral.cream}", "$type": "color" },
      "background-inverse": { "$value": "{color.brand.ink}", "$type": "color" },
      "accent": { "$value": "{color.brand.terracotta}", "$type": "color" },
      "secondary-accent": { "$value": "{color.brand.sage}", "$type": "color" },
      "border-default": { "$value": "{color.neutral.warm-gray-100}", "$type": "color" },
      "border-strong": { "$value": "{color.neutral.warm-gray-300}", "$type": "color" }
    }
  },
  "typography": {
    "family": {
      "heading": {
        "$value": "Crimson Pro",
        "$type": "fontFamily",
        "$description": "Editorial serif for headlines. Family default for Warm Editorial. Free on Google Fonts."
      },
      "body": {
        "$value": "Inter",
        "$type": "fontFamily",
        "$description": "Clean sans for body and UI."
      }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "xs": { "$value": "12px", "$type": "dimension" },
      "sm": { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "17px", "$type": "dimension", "$description": "Body slightly larger than Editorial Minimal — Warm Editorial reads more relaxed." },
      "lg": { "$value": "20px", "$type": "dimension" },
      "xl": { "$value": "24px", "$type": "dimension" },
      "2xl": { "$value": "30px", "$type": "dimension" },
      "3xl": { "$value": "38px", "$type": "dimension" },
      "4xl": { "$value": "48px", "$type": "dimension" },
      "5xl": { "$value": "64px", "$type": "dimension" },
      "6xl": { "$value": "84px", "$type": "dimension", "$description": "Hero serif headline on 1080×1350." }
    },
    "lineHeight": {
      "tight": { "$value": 1.15, "$type": "number" },
      "snug": { "$value": 1.3, "$type": "number" },
      "normal": { "$value": 1.65, "$type": "number", "$description": "Warm Editorial body breathes more than Editorial Minimal." }
    },
    "letterSpacing": {
      "tight": { "$value": "-0.015em", "$type": "dimension" },
      "normal": { "$value": "0em", "$type": "dimension" },
      "wide": { "$value": "0.06em", "$type": "dimension" }
    },
    "style": {
      "hero": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.semibold}",
          "fontSize": "{typography.size.6xl}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "h1": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.semibold}",
          "fontSize": "{typography.size.5xl}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "h2": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.heading}",
          "fontWeight": "{typography.weight.semibold}",
          "fontSize": "{typography.size.4xl}",
          "lineHeight": "{typography.lineHeight.snug}"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.base}",
          "lineHeight": "{typography.lineHeight.normal}"
        }
      },
      "caption": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.sm}",
          "lineHeight": "{typography.lineHeight.normal}"
        }
      }
    }
  },
  "spacing": {
    "0": { "$value": "0px", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0px", "$type": "dimension" },
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension", "$description": "Default for cards in Warm Editorial." },
    "lg": { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "canvas": {
    "linkedin-post": { "$value": { "width": 1080, "height": 1350 }, "$type": "dimension" },
    "linkedin-pdf": { "$value": { "width": 1080, "height": 1350 }, "$type": "dimension" },
    "article-header": { "$value": { "width": 1080, "height": 607 }, "$type": "dimension" },
    "one-pager": { "$value": { "width": 2480, "height": 3508 }, "$type": "dimension" }
  }
}
